{
	"compilerOptions": {
		"sourceMap": true,
		"strict": true,
		"noImplicitThis": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"module": "es2015",
		"target": "es2016",
		"typeRoots": ["./node_modules/@types"],
		"types": ["jquery"],
		"lib": ["dom", "es2016"],
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"rootDir": "./src",
	},
	"include": ["./src/**/*.ts"]
}
